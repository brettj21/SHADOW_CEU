## BROWSER CACHING
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/jpg "access 1 year"
	ExpiresByType image/jpeg "access 1 year"
	ExpiresByType image/gif "access 1 year"
	ExpiresByType image/png "access 1 year"
	ExpiresByType text/css "access 1 month"
	ExpiresByType text/html "access 1 month"
	ExpiresByType application/pdf "access 1 month"
	ExpiresByType text/x-javascript "access 1 month"
	ExpiresByType application/x-shockwave-flash "access 1 month"
	ExpiresByType image/x-icon "access 1 year"
	ExpiresDefault "access 1 month"
</IfModule>

#RewriteEngine On
#RewriteCond %{HTTPS} !=on
#RewriteRule ^.*$ https://%{SERVER_NAME}%{REQUEST_URI} [R,L]
#RewriteCond %{HTTP_HOST} ^ceunits.com
#RewriteRule (.*) http://www.ceunits.com/$1 [R=301,L]
#####
#removed tha above - added this 071023
RewriteCond %{HTTP_HOST} ^[^.]+\.[^.]+$
RewriteCond %{HTTPS}s ^on(s)|
RewriteRule ^ http%1://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

ErrorDocument 404 /404.php
RewriteRule ^404$ 404.php [L]

RewriteRule ^course_insert/$ course_insert/index.php [L]
RewriteRule ^Profession/(.*)$ /social-workers/$1 [R=301,NC,L] # USERS THAT DIDN'T END UP SELECTING PROFESSION

## LIVING WORKS
RewriteRule ^livingworks$ livingworks/index.php [L]
RewriteRule ^livingworks/$ livingworks/index.php [L]
RewriteRule ^livingworks/ce$ index_profession_livworks.php?by=lw [L]
RewriteRule ^livingworks/ce/$ index_profession_livworks.php?by=lw [L]
RewriteRule ^livingworks/register$ /register/?reg_tag=lw [L]
RewriteRule ^livingworks/register/$ /register/?reg_tag=lw [L]
RewriteRule ^livingworks/([0-9]+)/test/$ trainings/index.php?training_id=$1&extra=test [L]
RewriteRule ^livingworks/verify/([0-9]+)/$ livingworks/verify.php?tid=$1 [L]
RewriteRule ^livingworks/verify/x/([0-9]+)/$ livingworks/verify.php?tid=$1&er=1 [L] # THE x REPRESENTS THERE WAS AN ERROR

## MYOUTCOMES
RewriteRule ^myoutcomes myoutcomes/index.php [L]
RewriteRule ^myoutcomes/$ myoutcomes/index.php [L]

# 404 PAGES THAT NEEDED TO BE 404'd
RewriteRule ^([^/\.]+)/([0-9]+)/pd$ http://ceunits.com/404 [R=301,L,NC]
RewriteRule ^([^/\.]+)/([0-9]+)/pd/$ http://ceunits.com/404 [R=301,L,NC]
RewriteRule ^([^/\.]+)/top$ http://ceunits.com/404 [R=301,L,NC]
RewriteRule ^([^/\.]+)/top/$ http://ceunits.com/404 [R=301,L,NC]


#### REDIRECT ALL SUBDOMAINS TO 404
#RewriteCond %{HTTP_HOST} ^([a-z0-9\-]+)\.ceunits\.com$  [NC]
#RewriteCond %1 !^www$ [NC]
#RewriteRule (.*) http://ceunits.com/404 [R=301,L,NC]




##### FORM POST REWRITE
RewriteRule ^process/forms$ process/forms.php [L]

##### USER REDIRECT
RewriteRule ^user/receipt/([0-9]+)$ user/receipt.php?receipt_id=$1 [L]
RewriteRule ^user/receipt/([0-9]+)$ user/receipt.php?receipt_id=$1 [L]
RewriteRule ^user/$ user/index.php [L]
RewriteRule ^user/([^/\.]+)$ user/index.php?note=$1 [L] #SENDS TO USER PAGE ALERTING SUCCESS OR FAIL OF INFO UPDATE


##### ADMIN CAPTURE
RewriteRule ^admin/$ admin/index.php [L]
RewriteRule ^manage/$ manage/index.php [L]

##### CART
RewriteRule ^cart/$ cart/index.php [L]
RewriteRule ^cart/checkout/$ cart/checkout.php [L]
RewriteRule ^cart/checkout/ul$ cart/checkout_unlimited.php?ul=1 [L]

##### BLOG
RewriteRule ^blog/$ blog/index.php [L]

##### SITE LEVEL
RewriteRule ^trainings/training_answers/([0-9]+)$ trainings/training_answers.php?tn=$1 [L]
RewriteRule ^trainings$ index_profession.php [L]
RewriteRule ^trainings/$ index_profession.php [L]
RewriteRule ^trainings/pdf_download/([0-9]+)$ trainings/pdf_download.php?training_id=$1 [L]
RewriteRule ^trainings/pdf_download/([0-9]+)/$ trainings/pdf_download.php?training_id=$1 [L]
RewriteRule ^faq$ faq.php [L]
RewriteRule ^faq/$ faq.php [L]
RewriteRule ^policies$ policies.php [L]
RewriteRule ^policies/$ policies.php [L]
RewriteRule ^site_index$ site_index.php [L]
RewriteRule ^site_index/$ site_index.php [L]
RewriteRule ^contact$ contact.php [L]
RewriteRule ^contact/$ contact.php [L]
RewriteRule ^status$ status/index.php [L]
RewriteRule ^status/$ status/index.php [L]
RewriteRule ^map$ map/map.php [L]
RewriteRule ^map/$ map/map.php [L]
RewriteRule ^update_license$ register/lic_exp_update.php [L]
RewriteRule ^update_license/$ register/lic_exp_update.php [L]
RewriteRule ^cert/([0-9]+)$ cert.php?cid=$1 [L]
RewriteRule ^cert/([0-9]+)/$ cert.php?cid=$1 [L]

##### MOBILE REDIRECTS
RewriteRule ^mobile/$ mobile/index.php [L]


##### PROFESSION REDIRECT

RewriteRule ^nursing/$ http://www.ceunits.com/ [R=301,L] #NO LONGER AVAILABLE
RewriteRule ^insurance/$ http://www.ceunits.com/ [R=301,L] #INSURANCE NO LONGER AVAILABLE
###RewriteRule ^mft-lcsw/$ http://www.ceunits.com/mft-nbcc [R=301,L]
###RewriteRule ^counselor-addiction/$ http://www.ceunits.com/addiction-professional [R=301,L]

RewriteCond %{REQUEST_URI} !^/login/$
RewriteCond %{REQUEST_URI} !^/register/$
RewriteRule ^([^/\.]+)/$ index_profession.php?profession=$1 [L]
RewriteRule ^([^/\.]+)/all/$ index_profession.php?profession=$1&by=all [L]
RewriteRule ^([^/\.]+)/credits/$ index_profession.php?profession=$1&by=credits [L]
RewriteRule ^([^/\.]+)/top/$ index_profession.php?profession=$1&by=top [L]

##### MISC REDIRECTS
RewriteRule ^login/recover$ login/recover.php [L]
RewriteRule ^login/recover/([^/\.]+)$ login/recover.php?success=$1 [L]
RewriteRule ^login/recover/$ login/recover.php [L]
RewriteRule ^login/recover/([^/\.]+)$ login/recover.php?success=$1 [L]


##### TRAININGS #####
##### POST TEST
RewriteRule ^([^/\.]+)/([0-9]+)/test/$ trainings/index.php?profession=$1&training_id=$2&extra=test [L]
RewriteRule ^([^/\.]+)/([0-9]+)/post/$ trainings_v2/post.php?profession=$1&training_id=$2 [L]
##### TRAINING PRINTABLE
RewriteRule ^([^/\.]+)/([0-9]+)/printable/$ trainings/printable.php?profession=$1&training_id=$2&extra=test [L]
##### TRAINING LOAD DESCRIPTION
RewriteRule ^([^/\.]+)/([0-9]+)/desc/$ trainings/index.php?profession=$1&training_id=$2&extra=desc [L]
RewriteRule ^([^/\.]+)/([0-9]+)/desc$ trainings/index.php?profession=$1&training_id=$2&extra=desc [L]

# added &extra=desc to load desc for seo reasons
RewriteRule ^([^/\.]+)/([0-9]+)/([^/\.]+)$ trainings/index.php?profession=$1&training_id=$2&extra=desc [L]
RewriteRule ^([^/\.]+)/([0-9]+)/([^/\.]+)/$ trainings/index.php?profession=$1&training_id=$2&extra=desc [L]
#### TRAINING IFRAME FOR PUBLIC DOMAIN
RewriteRule ^([^/\.]+)/([0-9]+)/([^/\.]+)/pd$ trainings/index_iframe.php?profession=$1&training_id=$2 [L]
RewriteRule ^([^/\.]+)/([0-9]+)/([^/\.]+)/pd/$ trainings/index_iframe.php?profession=$1&training_id=$2 [L]

#redirecting old no good seo urls
RewriteRule ^([^/\.]+)/([0-9]+)$ trainings/index.php?profession=$1&training_id=$2&redir=301 [L]
RewriteRule ^([^/\.]+)/([0-9]+)/$ trainings/index.php?profession=$1&training_id=$2&redir=301 [L]

AddHandler php-stable .php
#AddHandler php-legacy .php

#mod_deflate COMPRESSION
AddOutputFilterByType DEFLATE application/javascript application/x-javascript
AddOutputFilterByType DEFLATE text/css text/html text/plain text/xml text/javascript

# BEGIN (mt) controlled settings
#AddHandler php-legacy .php
# END (mt) controlled settings
